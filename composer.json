{
    "name": "andrewgjohnson/imagecolorallocatefromstring",
    "type": "library",
    "description": "imagecolorallocatefromstring is a function that will allocate a color based on a string for your PHP GD images",
    "keywords": [
        "gd",
        "graphics",
        "image",
        "images"
    ],
    "homepage": "https://imagecolorallocatefromstring.agjgd.org",
    "license": "MIT",
    "authors": [
        {
            "name": "Andrew G Johnson",
            "email": "andrew@andrewgjohnson.com",
            "homepage": "https://www.andrewgjohnson.com/",
            "role": "Project Lead"
        }
    ],
    "require": {
        "php": ">=5.0.0",
        "ext-gd": "*"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpunit/phpunit": "^12.5",
        "squizlabs/php_codesniffer": "^3.13"
    },
    "autoload": {
        "files": [
            "source/imagecolorallocatefromstring.php"
        ]
    },
    "scripts": {
        "lint": "@php vendor/bin/phpcs",
        "lint:fix": "@php vendor/bin/phpcbf",
        "phpunit": "@php vendor/bin/phpunit",
        "test": [
            "@lint",
            "@phpunit"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
